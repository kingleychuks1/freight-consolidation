R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ── Shipping Rates API ────────────────────────────────────────────────────────
# Option A: Easyship
EASYSHIP_API_KEY="..."

# Option B: Shippo
SHIPPO_API_KEY="shippo_test_..."

# ── Admin ─────────────────────────────────────────────────────────────────────
